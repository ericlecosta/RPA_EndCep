@startuml rpa_end_cep
start

:Iniciar execução (main.py);

:Chamar baixar_arquivo();
:Download do CSV;
:Retornar caminho do arquivo;

:Chamar tratar_dados(caminho);
:Ler CSV;
:Limpar e tratar dados;
:Filtrar endereços válidos;
:Separar CEP;
:Criar amostra;

:Geocodificar endereços;
if (Coordenadas encontradas?) then (Sim)
  :Adicionar latitude/longitude;
else (Não)
  :Registrar falha;
endif

:Chamar gerar_mapa(df);
if (Há coordenadas válidas?) then (Sim)
  :Criar mapa (folium);
  :Adicionar marcadores;
else (Não)
  :Mapa vazio ou abortar;
endif

:Salvar mapa_enderecos.html;

stop
@enduml